# --- PRIVATE DATA: the board snapshot is internal task content + home paths. NEVER commit. ---
# The exporter writes here; the deploy injects it out-of-band (blob upload), never via git.
# /data/board.json* also covers transient backups like board.json.private-bak (real data).
/data/board.json
/data/board.json*
/data/*.board.json
/public/board.json
*.board.json
*.private-bak
board.json

# --- Secrets / env ---
.env
.env.*
!.env.example

# --- Agent-scratch class (this toolchain drops session-scoped scratch into working trees) ---
.ai-workspace/
.claude/
tmp/
_quarantine*/
*.log

# --- Node / Next / Vercel ---
node_modules/
# Also ignore a root-level node_modules SYMLINK (the worktree-node-modules-link
# hook points it at the primary clone). The trailing-slash pattern above matches
# only a directory, so without this a `git add -A` would stage the symlink and
# leak a /Users/<name>/ home path. (#1316)
/node_modules
.next/
out/
.vercel/
dist/
*.tsbuildinfo

# --- Playwright (e2e DOM-acceptance run artifacts; the specs under e2e/ ARE tracked) ---
test-results/
playwright-report/
.playwright/

# --- OS ---
.DS_Store

# --- git worktrees (intentional, e.g. live-deploy) — never tracked ---
.worktrees/

# --- Vercel CLI project link (created by `vercel link`) — machine-local, never tracked ---
.vercel/
